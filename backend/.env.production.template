# ══════════════════════════════════════════════════════════════════════════════
# SMART PE — Configuración de PRODUCCIÓN
# ══════════════════════════════════════════════════════════════════════════════
# INSTRUCCIONES:
#   1. Copia este archivo y renómbralo a .env en el servidor
#   2. Rellena TODOS los valores marcados con <CAMBIAR>
#   3. NUNCA subas este archivo con datos reales a Git
#   4. El servidor debe tener este archivo fuera del repositorio
# ══════════════════════════════════════════════════════════════════════════════

# ─── Base de Datos ────────────────────────────────────────────────────────────
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_db
DATABASE_URL=postgresql://<CAMBIAR_USUARIO>:<CAMBIAR_CONTRASENA>@localhost:5432/smart_pe_db

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Genera una clave nueva con:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=<CAMBIAR_GENERA_UNA_NUEVA_CLAVE>
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Entorno ─────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ─── CORS ────────────────────────────────────────────────────────────────────
# Lista de dominios separados por coma (SIN espacios, sin slash final)
CORS_ORIGINS=https://admin.tudominio.com,https://tienda.tudominio.com

# ─── Sentry (Monitoreo de Errores) ───────────────────────────────────────────
SENTRY_DSN=<CAMBIAR_TU_SENTRY_DSN>

# ─── NubeFact (Facturación SUNAT) ────────────────────────────────────────────
# En producción usar la URL y TOKEN del modo REAL (no Sandbox)
# Activar en: nubefact.com → "ACTIVAR CON LA SUNAT (Modo Producción)"
NUBEFACT_URL=<CAMBIAR_URL_PRODUCCION_NUBEFACT>
NUBEFACT_TOKEN=<CAMBIAR_TOKEN_PRODUCCION_NUBEFACT>
